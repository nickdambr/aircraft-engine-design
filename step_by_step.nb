       RowBox[{"Frame", "\[Rule]", "True"}], ",", "\[IndentingNewLine]", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<V[m/s]\>\"", ",", "\"\<h[m]\>\""}], "}"}]}]}], "]"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"cost", ",", "0", ",", "150", ",", "10"}], "}"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"ContourPlot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"h", "+", 
         RowBox[{
          RowBox[{"V", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "9.81"}], ")"}]}]}], "\[Equal]", "c1"}], ",", 
       RowBox[{"{", 
        RowBox[{"V", ",", "0", ",", "600"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"h", ",", "0", ",", "18000"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ContourStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Black", ",", "Thin"}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"ContourLabels", "\[Rule]", "None"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"c1", ",", "0", ",", "38000", ",", "1000"}], "}"}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]}], "Input",
 CellChangeTimes->{{3.66764639935225*^9, 3.6676465599298687`*^9}, {
