Cell[CellGroupData[{

Cell[TextData[{
 "Best Subsonic Cruise (@ Best Mach = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "crit"], ")"}], TraditionalForm]],ExpressionUUID->
  "5fd7d2da-b975-d346-b721-5c1e3bfdbc4a"]
}], "Subsection",
 CellChangeTimes->{{3.626519844846548*^9, 
  3.626519881356926*^9}},ExpressionUUID->"8688ff45-ac1d-6540-992e-\
03dce0d0ebe6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"piCRZ", "[", 
   RowBox[{
   "\[CapitalDelta]S_", ",", "C1_", ",", "C2_", ",", "M0_", ",", "CD0_", ",", 
    "CDR_", ",", "K1_", ",", "K2_", ",", "a_"}], "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"(", 
       RowBox[{
        FractionBox["C1", "M0"], "+", "C2"}], ")"}], "3600"]}], 
    RowBox[{"(", 
     RowBox[{
      SqrtBox[
