  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "s"], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"V", "/", "g0"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"dV", "/", "dt"}], ")"}]}]}], ")"}], TraditionalForm]],
