     RowBox[{"M0", "\[Rule]", "Mavg"}], ",", 
     RowBox[{"\[Gamma]", "\[Rule]", "1.4"}], ",", 
     RowBox[{"R", "\[Rule]", "287"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
