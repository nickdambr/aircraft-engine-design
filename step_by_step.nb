Cell[BoxData[{
 RowBox[{
  RowBox[{"g0", "=", "9.81"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hAcc", "=", "10000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p0Acc", "=", 
   RowBox[{"pstd", "[", "hAcc", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MAcc1", "=", "0.7"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MAcc2", "=", "0.8"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mavg", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"MAcc2", "+", "MAcc1"}], ")"}], "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"VAcc1", "=", 
   RowBox[{"MAcc1", "*", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"\[Gamma]", " ", "R", " ", 
      RowBox[{"Tstd", "[", "hAcc", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"VAcc2", "=", 
   RowBox[{"MAcc2", "*", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"\[Gamma]", " ", "R", " ", 
      RowBox[{"Tstd", "[", "hAcc", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalDelta]T", "=", "180"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dV", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"VAcc2", "-", "VAcc1"}], ")"}], "/", "\[CapitalDelta]T"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Beta]Acc", "=", "0.85"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"rule4", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Ps", "\[Rule]", 
      RowBox[{"V", "*", 
       RowBox[{"dV", "/", "g0"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"n", "\[Rule]", "1"}], ",", "\[IndentingNewLine]", 
     RowBox[{"q", "\[Rule]", 
      RowBox[{"0.5", " ", "\[Gamma]", " ", "p0Acc", " ", 
       RowBox[{"Mavg", "^", "2"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"h", "\[Rule]", "hTurn"}], ",", "\[IndentingNewLine]", 
     RowBox[{"\[Beta]", "\[Rule]", "\[Beta]Acc"}], ",", "\[IndentingNewLine]", 
     RowBox[{"\[Alpha]", "->", 
      RowBox[{"\[Alpha]TF", "[", 
       RowBox[{"hAcc", ",", "Mavg", ",", "TR"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"CDR", "\[Rule]", "0"}], ",", "\[IndentingNewLine]", 
     RowBox[{"K1", "->", 
      RowBox[{"k1", "[", 
       RowBox[{
       "commercial", ",", "fighter", ",", "Mavg", ",", "AR", ",", "e"}], 
       "]"}]}], ",", 
     RowBox[{"K2", "->", 
      RowBox[{"k2", "[", 
       RowBox[{"commercial", ",", "fighter"}], "]"}]}], ",", 
     RowBox[{"CD0", "\[Rule]", 
      RowBox[{"cd0", "[", 
       RowBox[{"commercial", ",", "fighter", ",", "Mavg"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"M0", "\[Rule]", "Mavg"}], ",", 
