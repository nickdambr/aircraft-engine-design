Cell[CellGroupData[{

Cell["Constant PS contours", "Subsection",
 CellChangeTimes->{{3.626519792401227*^9, 
  3.626519800194387*^9}},ExpressionUUID->"cc676e31-32ee-c94a-b7b7-\
2e6aba9f89a3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"V", 
   FractionBox[
    RowBox[{"(", 
     RowBox[{"T", "-", "D"}], ")"}], "W"]}], "=", 
  RowBox[{
   FractionBox[
    RowBox[{"d", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        SuperscriptBox["V", "2"], 
        RowBox[{"2", 
         SubscriptBox["g", "0"]}]], "+", "h"}], ")"}]}], "dt"], "=", 
   RowBox[{
    FractionBox[
     SubscriptBox["dz", "e"], "dt"], "=", 
    SubscriptBox["P", "S"]}]}]}]], "DisplayFormula",
 CellChangeTimes->{{3.667545566751316*^9, 
  3.667545679324078*^9}},ExpressionUUID->"2923e710-e539-ae42-ae4c-\
85b8a2bdccbb"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  SubscriptBox["z", "e"]],
  CellChangeTimes->{{3.667545566751316*^9, 3.667545679324078*^9}},
  ExpressionUUID->"df06441d-5ac0-bb4c-8243-2a52bd04a792"],
 " represents the aircraft mechanical energy (kinetic + potential) and is \
often referred to as \[OpenCurlyDoubleQuote]energy height\
\[CloseCurlyDoubleQuote]. ",
 Cell[BoxData[
  SubscriptBox["P", "S"]],
  CellChangeTimes->{{3.667545566751316*^9, 3.667545679324078*^9}},
  ExpressionUUID->"31a9a71b-a03f-7845-91db-7e9a109feb31"],
 " is the time rate of change of the energy height and is called weight \
specific excess power.\n\nOnce T/W and W/S are selected, it is possible to \
compute the weight specific excess power for flight at any chosen \[Beta], n, \
altitude, and velocity. ",
 "Fighter pilots routinely compare these Ps diagrams for their aircraft with \
those of their potential adversaries in order to determine where in the \
flight envelope they enjoy the greatest combat advantage.  CIAOOOOOOOOOOO"
}], "Text",
 CellChangeTimes->{{3.667545705677924*^9, 3.6675457472805443`*^9}, {
   3.66764538447748*^9, 3.667645419643323*^9}, 3.6676455549408503`*^9, {
   3.9519022809582214`*^9, 
   3.9519022962890835`*^9}},ExpressionUUID->"8760c7f9-9d23-f44c-990f-\
6ab3d5679f81"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"commercial", "=", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fighter", "=", "True"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Quiet", "[", 
   RowBox[{
    RowBox[{"rulePS", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"n", "\[Rule]", "1"}], ",", 
       RowBox[{"\[Beta]", "\[Rule]", "0.97"}], ",", 
       RowBox[{"\[Alpha]", "->", 
        RowBox[{"\[Alpha]TJmil", "[", 
         RowBox[{"h", ",", "M0", ",", "1.0"}], "]"}]}], ",", 
       RowBox[{"TW", "\[Rule]", "1."}], ",", 
       RowBox[{"WLG", "\[Rule]", "4000"}], ",", 
       RowBox[{"K1", "->", 
        RowBox[{"k1", "[", 
         RowBox[{
         "commercial", ",", "fighter", ",", "M0", ",", "AR", ",", "e"}], 
         "]"}]}], ",", 
       RowBox[{"K2", "->", 
        RowBox[{"k2", "[", 
         RowBox[{"commercial", ",", "fighter"}], "]"}]}], ",", 
       RowBox[{"CD0", "\[Rule]", 
        RowBox[{"cd0", "[", 
         RowBox[{"commercial", ",", "fighter", ",", "M0"}], "]"}]}], ",", 
       RowBox[{"q", "\[Rule]", 
        RowBox[{"0.5", " ", 
         RowBox[{"\[Rho]std", "[", 
          RowBox[{"h", ",", "0"}], "]"}], 
         RowBox[{"V", "^", "2"}]}]}], ",", 
       RowBox[{"M0", "\[Rule]", 
        RowBox[{"(", 
         RowBox[{"V", "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"\[Gamma]", " ", "R", " ", 
            RowBox[{"Tstd", "[", "h", "]"}]}], "]"}]}], ")"}]}], ",", 
       RowBox[{"AR", "\[Rule]", "8"}], ",", 
       RowBox[{"e", "\[Rule]", "0.8"}], ",", 
       RowBox[{"\[Gamma]", "\[Rule]", "1.4"}], ",", 
       RowBox[{"R", "\[Rule]", "287"}]}], "}"}]}], ";"}], "]"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Show", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ContourPlot", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"V", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              FractionBox["\[Alpha]", "\[Beta]"], "TW"}], "-", 
             RowBox[{"K1", " ", 
              RowBox[{"n", "^", "2"}], " ", 
              FractionBox["\[Beta]", "q"], " ", "WLG"}], " ", "-", " ", 
             RowBox[{"K2", " ", "n"}], " ", "-", " ", 
             FractionBox["CD0", 
              RowBox[{"\[Beta]", " ", 
               RowBox[{"WLG", "/", "q"}]}]]}], ")"}]}], "\[Equal]", "cost"}], 
         "//.", "rulePS"}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"V", ",", "0", ",", "600"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"h", ",", "0", ",", "18000"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"AspectRatio", "\[Rule]", "0.5"}], ",", "\[IndentingNewLine]", 
       RowBox[{"ContourLabels", "\[Rule]", "None"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"FrameStyle", "\[Rule]", 
        RowBox[{"Directive", "[", 
         RowBox[{"Black", ",", 
          RowBox[{"FontSize", "\[Rule]", "16"}], ",", 
          RowBox[{"FontFamily", "\[Rule]", "\"\<Arial\>\""}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Frame", "\[Rule]", "True"}], ",", "\[IndentingNewLine]", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<V[m/s]\>\"", ",", "\"\<h[m]\>\""}], "}"}]}]}], "]"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"cost", ",", "0", ",", "150", ",", "10"}], "}"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"ContourPlot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"h", "+", 
         RowBox[{
          RowBox[{"V", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "9.81"}], ")"}]}]}], "\[Equal]", "c1"}], ",", 
       RowBox[{"{", 
        RowBox[{"V", ",", "0", ",", "600"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"h", ",", "0", ",", "18000"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ContourStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"Black", ",", "Thin"}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"ContourLabels", "\[Rule]", "None"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"c1", ",", "0", ",", "38000", ",", "1000"}], "}"}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]}], "Input",
 CellChangeTimes->{{3.66764639935225*^9, 3.6676465599298687`*^9}, {
  3.758980924336656*^9, 3.758980942292841*^9}, {3.951902287174429*^9, 
