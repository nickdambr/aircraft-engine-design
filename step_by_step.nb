8981642cbd72"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"payloadrange", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"Wempty", "+", "Payload"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"range", "*", "m2nm"}], ",", 
       RowBox[{"Wempty", "+", "Payload"}]}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"towrange", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"Wempty", "+", "Payload"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"range", "*", "m2nm"}], ",", 
       RowBox[{"Wempty", "+", "Payload", "+", "Wfuel"}]}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FuelCapacity", " ", "=", " ", "20700"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PL", "=", "Payload"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Fu", "=", "Wfuel"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mtow", "=", "WTO"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"newrange", "=", "range"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"MTOW", "-", 
    RowBox[{"limited", " ", "range"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"While", "[", 
   RowBox[{
    RowBox[{"Fu", "<", "FuelCapacity"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"PL", "=", 
      RowBox[{"PL", "-", "50"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Fu", "=", 
      RowBox[{"WTO", "-", "Wempty", "-", "PL"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rangeguess", "=", "newrange"}], ";", "\[IndentingNewLine]", 
     RowBox[{"sol", "=", 
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{"mtow", "==", 
         RowBox[{"PL", "+", 
          RowBox[{"\[Beta]init", "*", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"piCRZ", "[", 
              RowBox[{"rng", ",", "c1TF", ",", "c2TF", ",", "Mcrz", ",", 
               RowBox[{"cd0", "[", 
                RowBox[{"commercial", ",", "fighter", ",", "Mcrz"}], "]"}], ",",
                "0", ",", 
               RowBox[{"k1", "[", 
                RowBox[{
                "commercial", ",", "fighter", ",", "Mcrz", ",", "AR", ",", 
                 "e"}], "]"}], ",", 
               RowBox[{"k2", "[", 
                RowBox[{"commercial", ",", "fighter"}], "]"}], ",", 
               RowBox[{"Sqrt", "[", 
                RowBox[{"1.4", "*", "287", "*", " ", 
                 RowBox[{"Tstd", "[", "hcrz", "]"}]}], "]"}]}], "]"}]}], 
            ")"}], "*", "mtow"}], "+", "Wempty"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"rng", ",", "rangeguess"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"newrange", "=", 
      RowBox[{"rng", "/.", "sol"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"payloadrange", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"newrange", "*", "m2nm"}], ",", 
         RowBox[{"Wempty", "+", "PL"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"towrange", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"newrange", "*", "m2nm"}], ",", 
         RowBox[{"Wempty", "+", "PL", "+", "Fu"}]}], "}"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Fuel", "-", "capacity", "-", 
    RowBox[{"limited", " ", "range"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"While", "[", 
  RowBox[{
   RowBox[{"PL", ">", "50"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PL", "=", 
     RowBox[{"PL", "-", "50"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Fu", "=", "FuelCapacity"}], ";", "\[IndentingNewLine]", 
    RowBox[{"tow", "=", 
     RowBox[{"Wempty", "+", "Fu", "+", "PL"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"rangeguess", "=", "newrange"}], ";", "\[IndentingNewLine]", 
    RowBox[{"sol", "=", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{"tow", "==", 
        RowBox[{"PL", "+", 
         RowBox[{"\[Beta]init", "*", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"piCRZ", "[", 
             RowBox[{"rng", ",", "c1TF", ",", "c2TF", ",", "Mcrz", ",", 
              RowBox[{"cd0", "[", 
               RowBox[{"commercial", ",", "fighter", ",", "Mcrz"}], "]"}], ",",
               "0", ",", 
              RowBox[{"k1", "[", 
               RowBox[{
               "commercial", ",", "fighter", ",", "Mcrz", ",", "AR", ",", 
                "e"}], "]"}], ",", 
              RowBox[{"k2", "[", 
               RowBox[{"commercial", ",", "fighter"}], "]"}], ",", 
              RowBox[{"Sqrt", "[", 
               RowBox[{"1.4", "*", "287", "*", " ", 
                RowBox[{"Tstd", "[", "hcrz", "]"}]}], "]"}]}], "]"}]}], ")"}],
           "*", "tow"}], "+", "Wempty"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"rng", ",", "rangeguess"}], "}"}]}], "]"}]}], ";", 
    RowBox[{"newrange", "=", 
     RowBox[{"rng", "/.", "sol"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"payloadrange", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"newrange", "*", "m2nm"}], ",", 
        RowBox[{"Wempty", "+", "PL"}]}], "}"}]}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"towrange", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"newrange", "*", "m2nm"}], ",", 
        RowBox[{"Wempty", "+", "PL", "+", "Fu"}]}], "}"}]}], "]"}]}]}], 
  "\[IndentingNewLine]", "]"}]}], "Input",
