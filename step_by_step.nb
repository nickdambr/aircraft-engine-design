Cell[CellGroupData[{

Cell["Service Ceiling", "Subsubsection",
 CellChangeTimes->{{3.951989710182535*^9, 3.9519897446320953`*^9}, {
  3.952150068938772*^9, 
  3.952150069287678*^9}},ExpressionUUID->"a2503516-1421-b849-9c86-\
345ee6b92182"],

Cell[TextData[{
 "The maximum altitude at which the aircraft can cruise still having \
100ft/min of remaining climb rate. The aircraft has to fly at its maximum \
efficiency attitude (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "L"], TraditionalForm]],ExpressionUUID->
  "49a9ea9c-1467-4b4e-8eb2-c965753d04c8"],
 "= ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{
     SubscriptBox["C", 
      SubscriptBox["D", "0"]], "\[Pi]", " ", "AR", " ", "e"}]], 
   TraditionalForm]],ExpressionUUID->"aaa32c94-9364-4842-9ec6-cd3240486701"],
 ") and full thrust"
}], "Text",
 CellChangeTimes->{{3.626091866105043*^9, 3.626091930179326*^9}, {
  3.626092375411318*^9, 3.626092377635198*^9}, {3.626095476303164*^9, 
  3.626095511277793*^9}, {3.626514678640765*^9, 3.6265146862347317`*^9}, {
  3.6265152553570433`*^9, 
  3.62651527609626*^9}},ExpressionUUID->"2cda31fa-5b8d-fe47-9164-\
d8f8499a2f08"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   FractionBox["dV", "dt"], TraditionalForm]],ExpressionUUID->
  "abdb7370-ca29-c743-b885-74f49df8a03f"],
 "=0\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "0c876664-829c-9d41-a118-4f28c65eb14a"],
 " (L=W)\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "L"], "assigned", " "}], TraditionalForm]],
  ExpressionUUID->"02f5c624-f566-3e4a-a8cb-2c1f7c9301a5"],
 "-> maximum efficiency ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "L"], TraditionalForm]],ExpressionUUID->
  "f12f3616-64d3-f448-8925-975cb9a9ecaa"],
 "\nh assigned\n",
 Cell[BoxData[
  FormBox[
   FractionBox["dh", "dt"], TraditionalForm]],ExpressionUUID->
  "6bee4df8-103c-a94f-b33c-c62dafaa8df5"],
 " assigned -> 0.5 m/s = 100 ft/min"
}], "Text",
 CellChangeTimes->{{3.6259818967096033`*^9, 3.625981982647327*^9}, 
   3.625982017801814*^9, {3.626091007155869*^9, 3.62609104864744*^9}, {
   3.626095288932517*^9, 3.626095303923113*^9}, {3.626095360276141*^9, 
   3.626095367077599*^9}, {3.951990062065279*^9, 3.9519900649089546`*^9}, 
   3.951990167942459*^9},ExpressionUUID->"0df69efe-5c6b-a442-8636-\
368740b01f38"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ht", "=", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hsc", "=", "16764"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p0sc", "=", 
   RowBox[{"pstd", "[", "hsc", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Beta]sc", "=", "0.78"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"M0Crit", "=", "0.8"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CLe", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{"cd0", "[", 
      RowBox[{"commercial", ",", "fighter", ",", "M0Crit"}], "]"}], "*", "Pi",
      " ", "AR", " ", "e"}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "Input",
