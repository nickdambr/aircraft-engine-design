Cell[TextData[{
 StyleBox["\nReal Data (Eurofighter Typhoon , EJ200 Mk.100)",
  FontWeight->"Bold"],
 "\n\nWing span = 10.95 m\nWing area = 51.2 m^2\nAR = 2.34\nLength = 15.96 m\n\
Height = 5.28 m\nEmpty weight = 11000 kg\nGross weight = 16000 kg\nMTOW = \
23500 Kg\nMax payload = 6500 kg\nSuperCruise Mach = 1.1\nMax Mach / Max speed \
@ altitude = 2.0 / 2495 km/h\nMax Mach / Max speed @ sea level = 1.25 / 1530 \
km/h\nService ceiling = 16764 m = 55000 ft\nInitial climb velocity : 255 m/s \
(climb at 11.000 m in circa 150 sec)\nG limit : +9 / -3 G\nInstantaneous turn \
rate (ITR) : circa 30 gradi/sec\nSupported turn rate (STR) : circa 20 \
gradi/sec\nRange = 2900 Km\nSeats = 1\nTO time < 8 s\n\n",
 StyleBox["Engine Design",
  FontColor->RGBColor[0, 0, 1]],
 "\n\nTwin-spool TurboFan with Afterburner\n3 stages LPC\n5 stages HPC\n1 \
stage HPT\n1 stages LPT\nInlet diameter = 0.74 m\nFan diameter = 0.74 m\n\
Overall Length = 4 m\nWeight = 1037 kg\n\n",
 StyleBox["Engine performance",
  FontColor->RGBColor[0, 0, 1]],
 "\n\nThrust @ TO without reheat = 20000 lbf = 90 kN\nThrust @ TO with reheat \
= 13500 lbf = 60 kN\nT/W = 10\nAir massflow @ TO =  75/77 kg/s \nSpecific \
thrust @ TO = ? m/s\nOPR = 26\nBPR = 0.4\n\nThrust @ CRZ =  lbf = ? N\nTSFC @ \
CRZ = ? Kg / N hr\nEstimated(*) air massflow @ CRZ \[TildeEqual] ? Kg/s \n\
Estimated(*) Specific thrust @ CRZ \[TildeEqual] ? m/s\n\n(*) Computed as \
\[Rho](h) ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "Fan"], TraditionalForm]],ExpressionUUID->
  "3d03b8f3-f875-3c4b-b65e-686e863514c5"],
 " ",
 Cell[BoxData[
  FormBox[
   SqrtBox["\[Gamma]RT"], TraditionalForm]],ExpressionUUID->
  "ef322c19-fbfe-1e47-b6dd-a97fd3b7e862"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "Fan"], TraditionalForm]],ExpressionUUID->
  "98a80edc-4690-dc41-887b-1b64ffa1bc39"],
 ", assuming ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "Fan"], TraditionalForm]],ExpressionUUID->
  "1a2d6551-5a34-bb4e-a6d3-8e72b3365395"],
 "=0.7"
}], "Text",
